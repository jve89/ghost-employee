# Email account (IMAP inbox – used for input emails)
EMAIL_ACCOUNT=your-email@example.com
EMAIL_PASSWORD=your-email-app-password
EMAIL_POLL_INTERVAL=60
RESTRICT_EMAIL_OUTPUTS=off
ALLOWED_SENDERS=sender1@example.com,sender2@example.com
DEFAULT_RECIPIENT=your-email@example.com

# OpenAI API Key
OPENAI_API_KEY=your-openai-api-key

# Safety Toggles
SAFE_MODE=off
REAL_EXECUTION=on
ENFORCE_WHITELIST=false

# Mailgun Configuration
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=your-domain.com
MAILGUN_FROM=Ghost Employee <postmaster@your-domain.com>
MAILGUN_TO_EMAIL=your-email@example.com

# Export Toggles
EXPORT_SHEETS=true
EXPORT_NOTION=true
EXPORT_AIRTABLE=false
ALLOWED_PRIORITIES=high,medium

# Google Sheets
GOOGLE_SERVICE_ACCOUNT_JSON=./credentials/google_sheets_service_account.json
GOOGLE_SHEET_ID=your-google-sheet-id

# Notion
NOTION_API_KEY=your-notion-api-key
NOTION_DATABASE_ID=your-notion-database-id

# Attachment Processing
ATTACHMENT_RETENTION_DAYS=30

# AWS
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_DEFAULT_REGION=eu-north-1

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
SLACK_API_TOKEN=your-slack-api-token
