{
  "job_name": "HR Onboarding Assistant",
  "job_id": "hr_onboarding_assistant",
  "watch_dir": "watched/hr_docs",
  "file_pattern": "*.txt",
  "run_interval_seconds": 60,
  "gpt_model": "gpt-4",
  "active": true,
  "retry_limit": 2,
  "input_channels": ["file", "email"],
  "task_triggers": [
    "onboarding",
    "new hire",
    "create onboarding package",
    "prepare HR documents"
  ],
  "export_destinations": [
    {
      "type": "file",
      "config": {
        "directory": "./exports/demo_client/hr_onboarding_assistant/"
      }
    }
  ],
  "template_config": {
    "enabled": true,
    "template_file": "templates/onboarding_checklist_template.docx",
    "output_dir": "./exports/demo_client/hr_onboarding_assistant/docs/"
  }
}
