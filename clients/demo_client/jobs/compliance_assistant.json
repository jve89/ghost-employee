{
  "job_name": "Compliance Assistant",
  "job_id": "compliance_assistant",
  "watch_dir": "watched/compliance_docs",
  "gpt_model": "gpt-4",
  "retry_limit": 2,
  "run_interval_seconds": 60,
  "file_pattern": "*.txt",
  "active": true,
  "export_destinations": [
    {
      "type": "file",
      "config": {
        "directory": "./exports/demo_client/compliance_assistant/"
      }
    },
    {
      "type": "email",
      "config": {
        "recipients": ["johanvanerkel@gmail.com"],
        "subject": "🛡️ Compliance Summary",
        "message": "Here's your compliance summary:\n\n{{summary}}\n\nTasks:\n{{tasks}}"
      }
    }
  ]
}
