{
  "job_name": "test_export_job",
  "job_id": "test_export_job",
  "active": true,
  "watch_dir": "watched/test_exports",
  "file_pattern": "*.txt",
  "gpt_model": "gpt-4",
  "run_interval_seconds": 60,
  "retry_limit": 2,
  "export_destinations": [
    {
      "type": "file",
      "config": {
        "directory": "./exports/test_export_job/"
      }
    },
    {
      "type": "log",
      "config": {}
    },
    {
      "type": "email",
      "config": {
        "recipients": ["jovanerkel@gmail.com"],
        "subject": "Test Summary",
        "message": "Summary:\n\n{{summary}}\n\nTasks:\n{{tasks}}"
      }
    }
  ]
}
