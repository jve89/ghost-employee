{
  "job_name": "Compliance Assistant",
  "job_id": "compliance_assistant",
  "active": true,
  "watch_dir": "watched/compliance_docs",
  "file_pattern": "*.txt",
  "gpt_model": "gpt-4",
  "run_interval_seconds": 60,
  "retry_limit": 2,
  "job_prompt": {
    "system": "You are a Compliance Assistant at a mid-sized financial company. Your job is to read internal documents and generate a short, formal summary and extract clearly defined action items.",
    "user": "Summarise the following compliance update. Identify actionable tasks with assignees or deadlines if mentioned."
  },
  "export_destinations": [
    {
      "type": "file",
      "config": {
        "directory": "./exports/compliance_assistant/"
      }
    },
    {
      "type": "log",
      "config": {}
    },
    {
      "type": "email",
      "config": {
        "recipients": ["jovanerkel@gmail.com"],
        "subject": "🛡️ Compliance Summary",
        "message": "Summary:\n\n{{summary}}\n\nTasks:\n{{tasks}}"
      }
    },
    {
      "type": "notion",
      "config": {
        "database_id": "1fed8de4f8a3806481c0ced3399fbe54"
      }
    }
  ]
}
